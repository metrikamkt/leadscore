# Token secreto que você inventa — usado para verificar o webhook no Facebook
VERIFY_TOKEN=coloque_qualquer_string_aleatoria_aqui

# Token da Página do Facebook (Meta Business Suite → Configurações → Acesso à API)
PAGE_ACCESS_TOKEN=

# ID do seu Pixel do Facebook (Events Manager)
PIXEL_ID=

# Token de acesso para a Conversions API (Events Manager → Configurações → Conversions API)
CAPI_ACCESS_TOKEN=

# Score mínimo para disparar a conversão (padrão: 7, ou seja, score > 7)
GOOD_LEAD_THRESHOLD=7
